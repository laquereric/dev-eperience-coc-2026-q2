<div class="mb-6">
  <h1 class="text-2xl font-bold"><%= template.name %></h1>
  <% if template.description.present? %>
    <p class="mt-1 text-gray-600"><%= template.description %></p>
  <% end %>
  <% if template.repo_url.present? %>
    <a href="<%= template.repo_url %>" class="mt-2 inline-block text-sm text-blue-600 hover:underline" target="_blank" rel="noopener">
      Repository
    </a>
  <% end %>
</div>
